<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_strictbase" model="ir.ui.view">
        <field name="name">res.partner.form.strictbase</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Header section fields -->
            <xpath expr="//field[@name='website']" position="after">
                <field name="moodle_website" widget="url"/>
                <field name="moodle_version"/>
                <field name="git_repo" widget="url"/>
                <field name="hosted_here"/>
            </xpath>

            <!-- Tab section -->
            <xpath expr="//page[@name='internal_notes']" position="before">
                <page string="StrictBase Details" name="strictbase_details">
                    <group>
                        <group string="Moodle/Usage">
                            <field name="main_use_case"/>
                            <field name="improvement_suggestions"/>
                        </group>
                        <group string="Infrastructure">
                            <field name="esp_implemented"/>
                            <field name="esp_we_pay"/>
                            <field name="esp_account_access"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
