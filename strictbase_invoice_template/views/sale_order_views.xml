<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_strictbase_invoice_template" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.strictbase.invoice.template</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='other_information']/group" position="after">
                <group string="Tax Note Preview" invisible="not strictbase_tax_note_preview">
                    <field
                        name="strictbase_tax_note_preview"
                        widget="html"
                        nolabel="1"
                        readonly="1"
                    />
                </group>
            </xpath>
        </field>
    </record>
</odoo>
