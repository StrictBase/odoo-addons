<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_strictbase_invoice_template" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.strictbase.invoice.template</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='invoicing_settings']" position="inside">
                <setting id="strictbase_invoice_background_upload"
                         string="StrictBase Invoice Background"
                         help="Upload the invoice background asset to use for the StrictBase PDF report. The file is stored in Odoo and is not shipped from the addon repository.">
                    <field name="strictbase_invoice_background_filename" invisible="1"/>
                    <field name="strictbase_invoice_background_image"
                           filename="strictbase_invoice_background_filename"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
