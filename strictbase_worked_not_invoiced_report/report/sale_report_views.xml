<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_report_worked_not_invoiced_list" model="ir.ui.view">
        <field name="name">sale.report.list.worked.not.invoiced</field>
        <field name="model">sale.report</field>
        <field name="arch" type="xml">
            <list
                string="Worked Not Invoiced"
                action="action_open_order"
                type="object"
                default_order="date asc, name asc, id"
            >
                <field name="date" optional="show"/>
                <field name="name" string="SO" class="fw-bold"/>
                <field name="partner_id" string="Customer" optional="show"/>
                <field name="product_id" string="Product" optional="show"/>
                <field name="qty_delivered" string="Qty Delivered" sum="Sum of Qty Delivered"/>
                <field name="qty_invoiced" string="Qty Invoiced" sum="Sum of Qty Invoiced"/>
                <field name="qty_to_invoice" string="Qty To Invoice" sum="Sum of Qty To Invoice"/>
                <field name="price_unit" string="Unit Price" widget="monetary" optional="show"/>
                <field
                    name="untaxed_amount_to_invoice"
                    string="Untaxed To Invoice"
                    widget="monetary"
                    optional="show"
                    sum="Sum of Untaxed To Invoice"
                />
                <field name="user_id" string="Salesperson" widget="many2one_avatar_user" optional="hide"/>
                <field name="line_invoice_status" column_invisible="True"/>
                <field name="product_type" column_invisible="True"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_sale_report_worked_not_invoiced_search" model="ir.ui.view">
        <field name="name">sale.report.search.worked.not.invoiced</field>
        <field name="model">sale.report</field>
        <field name="arch" type="xml">
            <search string="Worked Not Invoiced">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="user_id"/>
                <field name="date"/>

                <filter
                    name="filter_worked"
                    string="Worked"
                    domain="[('qty_delivered', '&gt;', 0)]"
                />
                <filter
                    name="filter_to_invoice_lines"
                    string="To Invoice"
                    domain="[('line_invoice_status', '=', 'to invoice')]"
                />
                <filter
                    name="filter_service_lines"
                    string="Services"
                    domain="[('product_type', '=', 'service')]"
                />
                <separator/>
                <filter
                    name="filter_billable_only"
                    string="Billable Only"
                    domain="[('price_unit', '&gt;', 0)]"
                />
                <filter
                    name="filter_zero_priced"
                    string="Zero-Priced"
                    domain="[('price_unit', '=', 0)]"
                />
                <separator/>
                <filter string="Date" name="filter_date" date="date"/>

                <group>
                    <filter string="Customer" name="group_partner_id" context="{'group_by': 'partner_id'}"/>
                    <filter string="Salesperson" name="group_user_id" context="{'group_by': 'user_id'}"/>
                    <filter string="Product" name="group_product_id" context="{'group_by': 'product_id'}"/>
                    <filter string="Order Date" name="group_date" context="{'group_by': 'date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_sale_worked_not_invoiced" model="ir.actions.act_window">
        <field name="name">Worked Not Invoiced</field>
        <field name="res_model">sale.report</field>
        <field name="view_mode">list,pivot,graph,form</field>
        <field name="view_id" ref="view_sale_report_worked_not_invoiced_list"/>
        <field name="search_view_id" ref="view_sale_report_worked_not_invoiced_search"/>
        <field name="domain">[('state', '=', 'sale')]</field>
        <field
            name="context"
        >{'search_default_filter_worked': 1, 'search_default_filter_to_invoice_lines': 1, 'search_default_filter_service_lines': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No worked service lines are currently waiting to be invoiced.
            </p>
            <p>
                Use the zero-priced filter to separate migration support-wallet lines from normal billable work.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_sale_reporting_worked_not_invoiced"
        name="Worked Not Invoiced"
        parent="sale.menu_sale_report"
        action="action_sale_worked_not_invoiced"
        groups="sales_team.group_sale_salesman"
        sequence="15"
    />
</odoo>
